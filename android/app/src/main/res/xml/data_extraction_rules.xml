<?xml version="1.0" encoding="utf-8"?>
<!--
  Auto-backup config — keep everything in the default backup set.
  No PII; nothing to exclude.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="root" />
    </cloud-backup>
    <device-transfer>
        <include domain="root" />
    </device-transfer>
</data-extraction-rules>
